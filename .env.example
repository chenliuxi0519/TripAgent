# ============================================================================
# Trip Agent - Environment Variables
# ============================================================================

# ============================================================================
# BACKEND (FastAPI travel-agent) — REQUIRED for trip planning
# ----------------------------------------------------------------------------
# The agent, Plan-and-Execute planner, multi-hop RAG and the FAISS long-term
# memory all run in the FastAPI backend (see ../travel-agent/backend).
# Local dev: leave EMPTY — the Vite proxy forwards /api -> 127.0.0.1:8000.
# Production: point to your deployed backend, including the /api suffix.
# VITE_BACKEND_URL=https://your-api.onrender.com/api
# ============================================================================

# ============================================================================
# FOR LOCAL DEVELOPMENT (Vite injects VITE_* vars into browser)
# Optional now: the browser LLM is only used for the status badge and the
# A2UI info-extraction fallback. Core planning uses the backend above.
# ============================================================================

# LLM API - Choose one provider:

# Option 1: GLM API (Recommended - 智谱 AI)
# Get your API key from: https://open.bigmodel.cn/usercenter/apikeys
VITE_GLM_API_KEY=your-glm-api-key-here
# VITE_GLM_MODEL=glm-4-flash

# Option 2: OpenAI API
# VITE_OPENAI_API_KEY=sk-your-openai-api-key-here
# VITE_OPENAI_MODEL=gpt-4o-mini

# Option 3: Anthropic Claude API
# VITE_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# External APIs (Optional - for real-time weather/places data):
# VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key_here
# VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ============================================================================
# FOR VERCEL DEPLOYMENT (Server-side, NOT exposed to browser)
# Set these in Vercel Dashboard > Settings > Environment Variables
# ============================================================================

# GLM_API_KEY=                # Server-side GLM API key
# OPENAI_API_KEY=             # Server-side OpenAI API key
# ANTHROPIC_API_KEY=          # Server-side Anthropic API key
# OPENWEATHER_API_KEY=        # Server-side OpenWeatherMap API key
# GOOGLE_PLACES_API_KEY=      # Server-side Google Places API key

# ============================================================================
# SUPABASE (Optional - for persistent storage in web deployment)
# ============================================================================

# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
